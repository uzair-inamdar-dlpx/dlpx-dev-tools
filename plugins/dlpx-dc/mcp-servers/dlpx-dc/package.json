{
  "name": "dlpx-dc",
  "version": "0.1.0",
  "description": "MCP server for Delphix dc CLI over SSH",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dlpx-dc": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --sourcemap --external:cpu-features --loader:.node=empty --banner:js=\"import{createRequire}from'module';import{fileURLToPath}from'url';import{dirname}from'path';const require=createRequire(import.meta.url);const __filename=fileURLToPath(import.meta.url);const __dirname=dirname(__filename);\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "smoke": "tsx scripts/smoke.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ssh2": "^1.15.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ssh2": "^1.15.0",
    "esbuild": "^0.24.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
